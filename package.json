{
  "name": "clinicalinsights-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server/dev.js",
    "dev:web": "node server/index.js",
    "api:setup": "python3 -m venv .venv && ./.venv/bin/python -m pip install -r requirements.txt",
    "api:dev": "./.venv/bin/python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "api:watch": "./.venv/bin/python -m uvicorn backend.main:app --reload --host 0.0.0.0 --port 8000",
    "api:start": "./.venv/bin/python -m uvicorn backend.main:app --host 0.0.0.0 --port 8000",
    "api:test": "./.venv/bin/python -m unittest discover -s backend/tests",
    "api:benchmark": "./.venv/bin/python backend/scripts/generate_reference_validation_report.py",
    "build": "vite build",
    "start": "NODE_ENV=production node server/index.js",
    "preview": "NODE_ENV=production PORT=4173 node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "jstat": "^1.9.6",
    "lucide-react": "^0.562.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "simple-statistics": "^7.8.8"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.3.16",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.1.2"
  }
}
